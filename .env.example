# Configuración de ejemplo - Copiar y renombrar según entorno necesario
# Entorno actual (development, staging, production)
VITE_NODE_ENV=development

# Backend API URLs
VITE_BACKEND_API_INCOR_HC=http://localhost:3000/
VITE_BACKEND_INCOR_LABORAL_API=http://localhost:8001/api/v1/
VITE_BACKEND_API_TURNOS=http://localhost:3001/api/
VITE_CONVERSATIONS_API_URL=http://localhost:3005/api/
VITE_CONVERSATIONS_WS_URL=http://localhost:3005/api/conversations/stream
VITE_CONVERSATIONS_ENABLED=false
VITE_CONVERSATIONS_NAV_VISIBLE=false
VITE_CONVERSATIONS_MOCK=false

# Frontend Base URL
VITE_BASE_URL=http://localhost:5173/

# Debug settings
VITE_DEBUG_MODE=true
VITE_SHOW_DEV_TOOLS=true

# Ejemplos para otros entornos:
#
# STAGING:
# VITE_BACKEND_API_INCOR_HC=https://staging-api.incorcentromedico.com.ar/api/
# VITE_BASE_URL=https://staging.miportal.incorcentromedico.com.ar/
#
# PRODUCTION:
# VITE_BACKEND_API_INCOR_HC=https://api.incorcentromedico.com.ar/api/
# VITE_BASE_URL=https://www.miportal.incorcentromedico.com.ar/
